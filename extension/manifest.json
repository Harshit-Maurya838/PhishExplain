{
  "manifest_version": 3,
  "name": "PhishExplain",
  "version": "1.0.0",
  "description": "Privacy-first phishing analysis of any webpage using a local AI + heuristic hybrid engine.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishExplain — Analyze This Page"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}
